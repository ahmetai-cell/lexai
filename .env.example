# ─────────────────────────────────────────────────
# LexAI – Environment Variables Template
# Kopyala: cp .env.example .env  ve değerleri doldur
# ─────────────────────────────────────────────────

# ── APP ──────────────────────────────────────────
APP_ENV=development          # development | staging | production
APP_SECRET_KEY=change-me-to-a-random-64-char-string
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_URL=http://localhost:3000

# ── DATABASE (PostgreSQL + pgvector) ─────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=lexai
POSTGRES_USER=lexai_user
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql+asyncpg://lexai_user:change-me@postgres:5432/lexai

# ── REDIS ────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── AWS / BEDROCK ─────────────────────────────────
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=lexai-documents
AWS_S3_REGION=us-east-1

# Bedrock – Claude 3.5 Sonnet
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_MAX_TOKENS=8192
BEDROCK_TEMPERATURE=0.1

# Bedrock – Titan Embeddings v2
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0
BEDROCK_EMBEDDING_DIMENSIONS=1536

# AWS Textract
TEXTRACT_REGION=us-east-1

# ── JWT AUTH ──────────────────────────────────────
JWT_SECRET_KEY=change-me-to-another-random-64-char-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── RAG ───────────────────────────────────────────
RAG_TOP_K=8
RAG_MIN_SIMILARITY=0.72
RAG_RERANKER_TOP_K=4
HALLUCINATION_THRESHOLD=0.80
HALLUCINATION_SENSITIVITY=high   # low | medium | high | critical

# ── RATE LIMITING ─────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_DAY=2000

# ── LOGGING ───────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json                  # json | text
